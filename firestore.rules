rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Transactions collection - user can only see their own transactions
    match /transactions/{document=**} {
      allow read, write: if request.auth.uid == resource.data.userID;
      allow create: if request.auth.uid == request.resource.data.userID;
    }
    
    // Budget plans collection - user can only see their own budget plans
    match /budgetPlans/{document=**} {
      allow read, write: if request.auth.uid == resource.data.userID;
      allow create: if request.auth.uid == request.resource.data.userID;
    }
    
    // Users collection - user can only edit their own profile
    match /users/{userID} {
      allow read, write: if request.auth.uid == userID;
    }
  }
}
